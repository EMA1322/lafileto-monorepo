{
  "name": "client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "build:analyze": "node ../../scripts/run-vite-analyze.mjs",
    "preview": "vite preview --port 4173 --strictPort",
    "lint": "pnpm exec eslint . --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "lint:fix": "pnpm exec eslint . --fix --no-error-on-unmatched-pattern",
    "format": "pnpm exec prettier . --write",
    "optimize:images": "node ../../scripts/optimize-images.mjs ./public/img",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@lafileto/shared-utils": "workspace:*",
    "@motionone/dom": "^10.18.0",
    "focus-trap": "^8.0.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "swiper": "^11"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "jsdom": "^25.0.1",
    "rollup-plugin-visualizer": "workspace:*",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
